{
    reknitJobs: [{
        infiles: "%self/content/story/*.html",
        outputType: "hugoPartial",
        outfile: "%self/layouts/story/single.html",
        template: "%self/src/html/template.html",
        options: {
            storyPageOptions: {
                gradeNames: "reknitr.storyPage.withVizLoader",
                mapFlavourGrade: ["hortis.libreMap.withMapboxData", "hortis.libreMap.withRegions", "hortis.libreMap.withRegionLegend"],
                // No zooms in this configuration
                zoomDuration: 0,
                slowZoomDuration: 0,
                gridResolution: 1000,
                regionFilterFieldNames: ["BEC"],
                selectors: {
                    /** This one is used for toggling **/
                    mapHolder: ".mxcw-map"
                }
            },

            components: {
                vizLoader: {
                    /** Paths relative to docs/story */
                    obsFile: "../data/tabular/Saanich_Tracheophyta_incomplete-aligned-catalogue_2025-08-26-reduced-labels.csv",
                    taxaFile: "../data/tabular/Saanich_Tracheophyta_incomplete-aligned-catalogue_2025-08-26-prepared-taxa.csv",
                    regionIndirectionFile: "../data/tabular/Saanich_Tracheophyta_incomplete-aligned-catalogue_2025-08-26-reduced-regionIndirection.csv"
                }
            },
            paneHandlers: {
                Vascular_BEC: {
                    type: "reknitr.paneHandler",
                    gradeNames: ["reknitr.paneHandler.withRegionLegend"]
                },
                Status: {
                    type: "reknitr.statusPaneHandler"
                },
                TopContributions: {
                    type: "reknitr.iNatComponentsPaneHandler",
                    iNatOptions: {
                        taxon: {
                            id: 211194,
                            str: "Vascular plants"
                        },
                        place: {
                            id: 81137,
                            str: "saanich"
                        },
                        features: [{ // recentObservations
                            desc: "This page lists the most recent observations of vascular plants made in the Saanich Peninsula. Click on any of them to go to the iNaturalist site for more information."
                        }, { // "commonTaxa"
                            desc: "This page lists the most commonly reported species in the Saanich Peninsula. You can use the dropdown at the top right to filter the results to a particular year."
                        }, { // "favourites",
                            desc: "Any time iNaturalist users encounter an observation they like, they can choose to \"favourite\" it. This page lists the most favourited vascular plants observations made in the the \xc1tl\u2019\u1e35a7tsem/Howe Sound Biosphere Region."
                        }
                        ]
                    }
                }
            }
        }
    }],
    copyJobs: [{ // TODO: Extend module-relative addressing to 3rd-party modules
        source: "%self/node_modules/@imerss/inat-components/dist/standalone.min.js",
        target: "%self/static/js/inat-components-standalone.min.js"
    }, {
        source: "%infusion/src/lib/jquery/core/js/jquery.js",
        target: "%self/static/js/jquery.js"
    }, {
        source: "%imerss-bioinfo/docs/js/imerss-viz-lib.js",
        target: "%self/static/js/imerss-viz-lib.js"
    }, {
        source: "%imerss-bioinfo/docs/js/imerss-viz-lib.js.map",
        target: "%self/static/js/imerss-viz-lib.js.map",
        replaceSource: "\"sourceRoot\":\"../..\"",
        replaceTarget: "\"sourceRoot\":\"../../../bagatelle/\""
    }, {
        source: "%imerss-bioinfo/docs/js/imerss-viz-new-core.js",
        target: "%self/static/js/imerss-viz-new-core.js"
    }, {
        source: "%imerss-bioinfo/docs/js/imerss-viz-new-core.js.map",
        target: "%self/static/js/imerss-viz-new-core.js.map",
        replaceSource: "\"sourceRoot\":\"../..\"",
        replaceTarget: "\"sourceRoot\":\"../../../bagatelle/\""
    }, {
        source: "%imerss-bioinfo/docs/js/imerss-viz-new.js",
        target: "%self/static/js/imerss-viz-new.js"
    }, {
        source: "%imerss-bioinfo/docs/js/imerss-viz-new.js.map",
        target: "%self/static/js/imerss-viz-new.js.map",
        replaceSource: "\"sourceRoot\":\"../..\"",
        replaceTarget: "\"sourceRoot\":\"../../../bagatelle/\""
    }, {
        source: "%imerss-bioinfo/docs/js/imerss-viz.js",
        target: "%self/static/js/imerss-viz.js"
    }, {
        source: "%imerss-bioinfo/docs/js/imerss-blitz.js",
        target: "%self/static/js/imerss-blitz.js"
    }, {
        source: "%imerss-bioinfo/src/client/img/Arrow-up.svg",
        target: "%self/docs/img/Arrow-up.svg"
    }, {
        source: "%imerss-bioinfo/src/client/img/Arrow-down.svg",
        target: "%self/docs/img/Arrow-down.svg"
    }, {
        source: "%imerss-bioinfo/src/client/img/up-arrow.svg",
        target: "%self/docs/img/up-arrow.svg"
    }, {
        source: "%imerss-bioinfo/src/client/img/external-link.svg",
        target: "%self/docs/img/external-link.svg"
    },  {
        source: "%self/img/download.svg",
        target: "%self/docs/img/download.svg"
    }, {
        source: "%self/img/12993632-large.jpeg",
        target: "%self/docs/img/12993632-large.jpeg"
    }, {
        source: "%imerss-bioinfo/docs/css/imerss-viz-lib.css",
        target: "%self/static/css/imerss-viz-lib.css"
    }, {
        source: "%imerss-bioinfo/docs/css/imerss-viz-new-core.css",
        target: "%self/static/css/imerss-viz-new-core.css"
    }, {
        source: "%imerss-bioinfo/docs/css/imerss-viz-new.css",
        target: "%self/static/css/imerss-viz-new.css"
    }, {
        source: "%imerss-bioinfo/docs/css/imerss-blitz.css",
        target: "%self/static/css/imerss-blitz.css"
    }, {
        source: "%self/outputs",
        target: "%self/docs/data/tabular"
    }]
}
